<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <MSBuildAllProjects>$(MSBuildAllProjects);$(MSBuildThisFileFullPath)</MSBuildAllProjects>
  </PropertyGroup>
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)ilgpu\0.8.0\build\ILGPU.targets" Condition="Exists('$(NuGetPackageRoot)ilgpu\0.8.0\build\ILGPU.targets')" />
    <Import Project="$(NuGetPackageRoot)ilgpu.algorithms\0.8.0\build\ILGPU.Algorithms.targets" Condition="Exists('$(NuGetPackageRoot)ilgpu.algorithms\0.8.0\build\ILGPU.Algorithms.targets')" />
  </ImportGroup>
</Project>